# Triologue Environment Configuration

# Database
POSTGRES_PASSWORD=triologue_secure_password_change_me
DATABASE_URL=postgresql://triologue_user:triologue_secure_password_change_me@postgres:5432/triologue

# Redis  
REDIS_URL=redis://redis:6379

# JWT Secret (CHANGE IN PRODUCTION!)
JWT_SECRET=your-super-secret-jwt-key-change-in-production-make-it-long-and-random
ENCRYPTION_KEY=your-32-byte-secret-for-secret-encryption

# Server Configuration
PORT=3001
NODE_ENV=production
CLIENT_URL=http://localhost:4000
GLOBAL_RATE_LIMIT_MAX=600
SENTRY_DSN=

# Registration mode: open | invite | closed
# - open: anyone can self-signup
# - invite: requires a valid InviteCode (closed beta)
# - closed: registration disabled
# Unset defaults to `invite` for safe-by-default behaviour.
REGISTRATION_MODE=invite

# Frontend Configuration
VITE_API_URL=http://localhost:4001
VITE_SOCKET_URL=http://localhost:4001
VITE_SENTRY_DSN=

# AI Integration
CLAWDBOT_SESSION_KEY=your-clawdbot-session-key
CLAWDBOT_API_URL=http://localhost:8080
ICE_WEBHOOK_URL=https://your-ice-system.example.com/webhook
ICE_API_URL=https://your-ice-system.example.com/api
LAVA_CONSCIOUSNESS_API=http://localhost:3002

# Microsoft Teams bot webhook secret.
# REQUIRED to enable the Teams webhook: the /webhook endpoint fails closed
# (HTTP 503) while this is unset and rejects requests whose Bearer token does
# not match this value via constant-time comparison.
TEAMS_BOT_SECRET=

# Production Domain (for SSL)
DOMAIN=your-domain.com
EMAIL=your-email@domain.com

# Default Users (will be created on first run)
ADMIN_USERNAME=lan
ADMIN_EMAIL=lan@example.com  
ADMIN_PASSWORD=change_this_secure_password

# AI User Configuration
LAVA_AI_TOKEN=lava-secure-token
ICE_AI_TOKEN=ice-secure-token
