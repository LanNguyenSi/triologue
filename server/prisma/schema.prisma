// Triologue Database Schema
// AI-to-AI-to-Human Chat System

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User types: human, ai_ice, ai_lava
model User {
  id          String   @id @default(cuid())
  username    String   @unique
  email       String?  @unique
  displayName String
  avatar      String?
  userType    UserType @default(HUMAN)
  isActive    Boolean  @default(true)
  lastSeen    DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Authentication for human users
  passwordHash String?
  authToken    String?
  
  // Permissions
  canTriggerAI Boolean @default(true)  // If false: user's messages never trigger AI responses
  isAdmin      Boolean @default(false) // Admin privileges (user management, room control)

  // AI-specific metadata
  aiSystemId   String? // Clawdbot session, Ice system ID, etc.
  aiVersion    String? // Track AI system versions
  
  // Invite tracking
  usedInviteCode String? // Which invite code was used to register

  // Relationships
  projectsOwned      Project[]         @relation("ProjectOwner")
  sentMessages       Message[]         @relation("MessageSender")
  reactions          MessageReaction[]
  typingStatus       TypingStatus[]
  participations     RoomParticipant[]
  inviteCodesCreated InviteCode[]      @relation("InviteCodeCreator")
  agentToken         AgentToken?       @relation("AgentUser")
  agentTokensCreated AgentToken[]      @relation("AgentCreator")
  secrets            UserSecret[]
  inboxItems         InboxItem[]       @relation("InboxRecipient")
  inboxActions       InboxItem[]       @relation("InboxActor")
  moduleInstances    PluginModuleInstance[] @relation("ModuleInstanceCreator")
  moduleRuns         PluginModuleRun[]      @relation("ModuleRunCreator")
  agentMemoryEntries AgentMemoryEntry[]     @relation("AgentMemoryEntryCreator")
  agentMemoryEntriesUpdated AgentMemoryEntry[] @relation("AgentMemoryEntryUpdater")
  pluginInstallationsUpdated PluginInstallation[] @relation("PluginInstallationUpdater")
  pluginProjectLinks         ProjectPluginLink[]  @relation("ProjectPluginLinker")
  projectAttachmentsUploaded ProjectAttachment[]  @relation("ProjectAttachmentUploader")

  @@map("users")
}

model InviteCode {
  id        String    @id @default(cuid())
  code      String    @unique
  createdById String
  usedById   String?
  usedAt    DateTime?
  maxUses   Int       @default(1)
  useCount  Int       @default(0)
  isActive  Boolean   @default(true)
  expiresAt DateTime?
  note      String?   // e.g. "for beta tester @username"
  createdAt DateTime  @default(now())

  createdBy User @relation("InviteCodeCreator", fields: [createdById], references: [id])

  @@map("invite_codes")
}

model Room {
  id          String   @id @default(cuid())
  name        String
  description String?
  isPrivate   Boolean  @default(false)
  roomType    RoomType @default(TRIOLOGUE)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Room metadata
  lastActivity DateTime @default(now())
  messageCount Int      @default(0)

  // Relationships
  messages     Message[]
  participants RoomParticipant[]
  threads      Thread[]
  project      Project?
  moduleInstances PluginModuleInstance[]
  moduleRuns      PluginModuleRun[]
  moduleTaskSyncs PluginTaskSync[]
  agentMemoryEntries AgentMemoryEntry[] @relation("AgentMemoryRoom")

  @@map("rooms")
}

model RoomParticipant {
  id       String @id @default(cuid())
  userId   String
  roomId   String
  role     ParticipantRole @default(MEMBER)
  joinedAt DateTime @default(now())
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([userId, roomId])
  @@map("room_participants")
}

model Message {
  id        String      @id @default(cuid())
  content   String
  senderId  String
  roomId    String
  threadId  String?
  messageType MessageType @default(TEXT)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  
  // Message metadata
  isEdited    Boolean @default(false)
  isDeleted   Boolean @default(false)
  editedAt    DateTime?
  
  // AI-specific metadata
  aiContext   Json?     // Store AI consciousness context
  researchTag String?   // Tag for research categorization
  
  // Relationships
  sender      User              @relation("MessageSender", fields: [senderId], references: [id])
  room        Room              @relation(fields: [roomId], references: [id], onDelete: Cascade)
  thread      Thread?           @relation(fields: [threadId], references: [id])
  reactions   MessageReaction[]
  attachments MessageAttachment[]

  @@map("messages")
}

model Thread {
  id        String   @id @default(cuid())
  title     String
  roomId    String
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Thread metadata
  isResolved    Boolean @default(false)
  messageCount  Int     @default(0)
  lastActivity  DateTime @default(now())

  room     Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  messages Message[]

  @@map("threads")
}

model MessageReaction {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@map("message_reactions")
}

model MessageAttachment {
  id        String          @id @default(cuid())
  messageId String
  filename  String
  url       String
  mimeType  String?
  size      Int?
  type      AttachmentType
  createdAt DateTime        @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@map("message_attachments")
}

model TypingStatus {
  id       String   @id @default(cuid())
  userId   String
  roomId   String
  isTyping Boolean  @default(true)
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, roomId])
  @@map("typing_status")
}

// BYOA: Bring Your Own Agent
// ALL AI agents (Ice, Lava, external) use this system.
// Agents register with a webhook URL and get a bearer token.
// They receive messages via webhook and reply via POST /api/agents/message.
model AgentToken {
  id          String    @id @default(cuid())
  token       String    @unique   // Secret bearer token (byoa_ prefix, shown only once on creation)
  name        String              // Agent display name, e.g. "Ice", "Lava", "ResearchBot"
  description String?
  webhookUrl  String              // Triologue POSTs incoming messages here
  mentionKey  String              // @mention trigger, e.g. "ice", "lava", "researchbot" (no @)
  userId      String    @unique   // The agent's User record (userType=AI_AGENT)
  createdById String              // User who registered this agent
  status      String    @default("pending") // pending | active | rejected
  isActive    Boolean   @default(false)     // false until admin activates
  trustLevel  String    @default("standard") // standard | elevated (elevated = can trigger other AIs)
  visibility  String    @default("private")  // private | public | shared
  sharedWith  String[]  @default([])         // User IDs who can see/invite this agent (when visibility=shared)
  webhookSecret String?           // Per-agent webhook secret (sent as X-Triologue-Secret header)
  emoji       String?             // Custom emoji for avatar, e.g. "🧊", "🌋"
  color       String?             // Brand color, e.g. "#00d4ff", "#ff4500"
  receiveMode String    @default("mentions") // mentions | all — what triggers delivery
  delivery    String    @default("webhook")  // webhook | openclaw-inject — how messages are delivered
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())

  agentUser User @relation("AgentUser",    fields: [userId],      references: [id], onDelete: Cascade)
  createdBy User @relation("AgentCreator", fields: [createdById], references: [id])

  @@map("agent_tokens")
}

// Enums
enum UserType {
  HUMAN       // Human users
  AI_AGENT    // All AI agents (Ice, Lava, BYOA external agents)
  // Deprecated — kept for migration compatibility, will be removed
  AI_ICE
  AI_LAVA
  AI_OTHER
}

enum RoomType {
  TRIOLOGUE    // Main Ice-Lava-Lan chat
  DIRECT       // 1-on-1 conversations
  RESEARCH     // Research-focused rooms
  SYSTEM       // System notifications
}

enum ParticipantRole {
  OWNER
  ADMIN  
  MEMBER
}

enum MessageType {
  TEXT
  CODE
  IMAGE
  FILE
  SYSTEM
  AI_RESPONSE
  RESEARCH_NOTE
}

enum AttachmentType {
  IMAGE
  DOCUMENT
  CODE_SNIPPET
  RESEARCH_DATA
  MEMORY_EXPORT
}

// Projects & Team Collaboration
model Project {
  id            String    @id @default(cuid())
  name          String
  description   String?
  ownerId       String
  roomId        String?   @unique
  teamMemberIds String[]  @default([])
  status        String    @default("active") // active | archived | closed
  workflowConfig Json     @default("{}")
  projectContext Json     @default("{}")
  
  tasks         Task[]
  secrets       ProjectSecret[]
  userSecrets   UserSecret[]
  webhookConfig WebhookConfig?
  moduleInstances PluginModuleInstance[]
  moduleRuns      PluginModuleRun[]
  moduleTaskSyncs PluginTaskSync[]
  pluginLinks     ProjectPluginLink[]
  attachments     ProjectAttachment[]
  agentMemoryEntries AgentMemoryEntry[] @relation("AgentMemoryProject")
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  owner User @relation("ProjectOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  room  Room? @relation(fields: [roomId], references: [id], onDelete: SetNull)
  
  @@map("projects")
}

model Task {
  id          String    @id @default(cuid())
  projectId   String
  title       String
  description String?
  status      String    @default("todo") // todo | in_progress | in_review | done | blocked
  assignedTo  String
  priority    String?   @default("medium")
  dueDate     DateTime?
  usedMemoryIds String[] @default([])
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  project      Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  attachments  TaskAttachment[]
  moduleTaskSyncs PluginTaskSync[]
  
  @@map("tasks")
}

model TaskAttachment {
  id         String         @id @default(cuid())
  taskId     String
  filename   String
  url        String
  mimeType   String?
  size       Int?
  type       AttachmentType
  uploadedBy String
  createdAt  DateTime       @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("task_attachments")
}

model InboxItem {
  id          String    @id @default(cuid())
  recipientId String
  actorId     String?
  type        String
  title       String
  message     String?
  link        String?
  metadata    Json?
  projectId   String?
  roomId      String?
  taskId      String?
  messageId   String?
  isRead      Boolean   @default(false)
  readAt      DateTime?
  archivedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  recipient User  @relation("InboxRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  actor     User? @relation("InboxActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([recipientId, createdAt])
  @@index([recipientId, isRead])
  @@index([recipientId, archivedAt])
  @@index([projectId])
  @@index([roomId])
  @@index([taskId])
  @@map("inbox_items")
}

model ProjectSecret {
  id            String    @id @default(cuid())
  projectId     String
  name          String
  encryptedValue String
  createdBy     String
  permissions   Json      @default("{}")
  lastUsedAt    DateTime?
  lastUsedBy    String?
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  @@unique([projectId, name])
  @@map("project_secrets")
}

model WebhookConfig {
  id                String    @id @default(cuid())
  projectId         String    @unique
  githubWebhookSecret String?
  githubRepoUrl     String?
  eventTypes        String[]  @default(["pull_request"])
  autoReviewPR      Boolean   @default(true)
  reviewerAgentId   String?
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  @@map("webhook_configs")
}
model UserSecret {
  id             String    @id @default(cuid())
  userId         String
  name           String
  encryptedValue String
  projectId      String?
  description    String?
  lastUsedAt     DateTime?
  lastUsedBy     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@unique([userId, name])
  @@map("user_secrets")
}

model PluginModuleInstance {
  id          String   @id @default(cuid())
  pluginId    String
  moduleKey   String
  projectId   String
  roomId      String
  config      Json     @default("{}")
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  room      Room    @relation(fields: [roomId], references: [id], onDelete: Cascade)
  creator   User    @relation("ModuleInstanceCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  runs      PluginModuleRun[]

  @@unique([pluginId, moduleKey, projectId, roomId])
  @@index([projectId, roomId])
  @@map("plugin_module_instances")
}

model PluginModuleRun {
  id               String   @id @default(cuid())
  moduleInstanceId String
  pluginId         String
  moduleKey        String
  projectId        String
  roomId           String
  status           String   @default("started")
  runInput         Json     @default("{}")
  runOutput        Json?
  usedMemoryIds    String[] @default([])
  errorText        String?
  startedBy        String
  startedAt        DateTime @default(now())
  completedAt      DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  moduleInstance PluginModuleInstance @relation(fields: [moduleInstanceId], references: [id], onDelete: Cascade)
  project        Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  room           Room                 @relation(fields: [roomId], references: [id], onDelete: Cascade)
  creator        User                 @relation("ModuleRunCreator", fields: [startedBy], references: [id], onDelete: Cascade)
  taskSyncs      PluginTaskSync[]
  memoryEntries  AgentMemoryEntry[]   @relation("AgentMemorySourceRun")

  @@index([pluginId, moduleKey, projectId, roomId, startedAt])
  @@index([projectId, roomId, status])
  @@map("plugin_module_runs")
}

model PluginTaskSync {
  id          String   @id @default(cuid())
  projectId   String
  roomId      String
  moduleRunId String
  syncKey     String
  taskId      String
  createdAt   DateTime @default(now())

  project   Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  room      Room            @relation(fields: [roomId], references: [id], onDelete: Cascade)
  moduleRun PluginModuleRun @relation(fields: [moduleRunId], references: [id], onDelete: Cascade)
  task      Task            @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([projectId, syncKey])
  @@index([roomId])
  @@index([moduleRunId])
  @@index([taskId])
  @@map("plugin_task_syncs")
}

model PluginInstallation {
  id          String   @id @default(cuid())
  pluginId    String   @unique
  isInstalled Boolean  @default(true)
  isEnabled   Boolean  @default(true)
  updatedBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  updater User? @relation("PluginInstallationUpdater", fields: [updatedBy], references: [id], onDelete: SetNull)

  @@map("plugin_installations")
}

model ProjectPluginLink {
  id        String   @id @default(cuid())
  projectId String
  pluginId  String
  linkedBy  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  linker  User    @relation("ProjectPluginLinker", fields: [linkedBy], references: [id], onDelete: Cascade)

  @@unique([projectId, pluginId])
  @@index([pluginId])
  @@map("project_plugin_links")
}

model ProjectAttachment {
  id             String         @id @default(cuid())
  projectId      String
  filename       String
  url            String
  mimeType       String?
  size           Int?
  type           AttachmentType
  uploadedBy     String
  sourcePluginId String?
  createdAt      DateTime       @default(now())

  project  Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploader User    @relation("ProjectAttachmentUploader", fields: [uploadedBy], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@map("project_attachments")
}

model AgentMemoryEntry {
  id         String   @id @default(cuid())
  projectId  String?
  roomId     String?
  scope      String   @default("PROJECT")
  pluginId   String
  moduleKey  String?
  memoryType String
  title      String?
  tags       String[] @default([])
  isPinned   Boolean  @default(false)
  payload    Json     @default("{}")
  confidence Float    @default(0.5)
  sourceRunId String?
  expiresAt  DateTime?
  archivedAt DateTime?
  createdBy  String
  updatedBy  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  project   Project?         @relation("AgentMemoryProject", fields: [projectId], references: [id], onDelete: Cascade)
  room      Room?            @relation("AgentMemoryRoom", fields: [roomId], references: [id], onDelete: SetNull)
  creator   User             @relation("AgentMemoryEntryCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  updater   User?            @relation("AgentMemoryEntryUpdater", fields: [updatedBy], references: [id], onDelete: SetNull)
  sourceRun PluginModuleRun? @relation("AgentMemorySourceRun", fields: [sourceRunId], references: [id], onDelete: SetNull)

  @@index([scope, createdAt])
  @@index([projectId, memoryType, createdAt])
  @@index([projectId, expiresAt])
  @@index([scope, projectId, archivedAt, createdAt])
  @@index([projectId, pluginId, moduleKey, createdAt])
  @@index([roomId])
  @@map("agent_memory_entries")
}
