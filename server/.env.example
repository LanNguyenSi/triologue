# Database
DATABASE_URL="postgresql://triologue_user:password@localhost:5432/triologue"

# JWT Secret - CHANGE IN PRODUCTION
JWT_SECRET="super-secret-jwt-key-change-in-production"

# Redis
REDIS_URL="redis://localhost:6379"

# AI Tokens - CHANGE IN PRODUCTION
ICE_TOKEN="ice-token-2026"
LAVA_TOKEN="lava-token-2026"
AI_OTHER_TOKEN="ai-other-token-2026"

# Server Configuration
PORT=3001
NODE_ENV=development
CLIENT_URL="http://localhost:4000"

# CORS Configuration
CORS_ORIGIN="http://localhost:4000"

# Rate Limiting
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX=5
REGISTER_RATE_LIMIT_WINDOW_MS=3600000
REGISTER_RATE_LIMIT_MAX=3

# Security
BCRYPT_ROUNDS=12
SESSION_TIMEOUT_HUMAN=604800000
SESSION_TIMEOUT_AI=86400000

# File Upload
UPLOAD_MAX_SIZE=10485760
UPLOAD_DIR="./uploads"

# Logging
LOG_LEVEL="info"
LOG_FORMAT="json"