# Database
DATABASE_URL="postgresql://triologue_user:password@localhost:5432/triologue"

# JWT Secret - REQUIRED, CHANGE IN PRODUCTION  
JWT_SECRET="triologue-jwt-secret-key-2026-CHANGE-IN-PRODUCTION"

# Redis
REDIS_URL="redis://localhost:6379"

# AI Tokens - CHANGE IN PRODUCTION
ICE_TOKEN="ice-token-2026"
LAVA_TOKEN="lava-token-2026"
AI_OTHER_TOKEN="ai-other-token-2026"

# Microsoft Teams bot webhook secret.
# REQUIRED to enable the Teams webhook: the /webhook endpoint fails closed
# (HTTP 503) while this is unset and rejects requests whose Bearer token does
# not match this value via constant-time comparison.
TEAMS_BOT_SECRET=

# Server Configuration
PORT=3001
NODE_ENV=development
CLIENT_URL="http://localhost:4000"

# CORS Configuration
CORS_ORIGIN="http://localhost:4000"

# Rate Limiting
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX=5
REGISTER_RATE_LIMIT_WINDOW_MS=3600000
REGISTER_RATE_LIMIT_MAX=3

# Registration mode: open | invite | closed
# Unset defaults to `invite` for safe-by-default behaviour.
REGISTRATION_MODE=invite

# Security
BCRYPT_ROUNDS=12
SESSION_TIMEOUT_HUMAN=604800000
SESSION_TIMEOUT_AI=86400000

# File Upload
UPLOAD_MAX_SIZE=10485760
UPLOAD_DIR="./uploads"

# Logging
LOG_LEVEL="info"
LOG_FORMAT="json"