# Database
DATABASE_URL="postgresql://triologue_user:password@localhost:5432/triologue"

# JWT Secret - REQUIRED, CHANGE IN PRODUCTION  
JWT_SECRET="triologue-jwt-secret-key-2026-CHANGE-IN-PRODUCTION"

# Redis
REDIS_URL="redis://localhost:6379"

# AI Tokens - CHANGE IN PRODUCTION
ICE_TOKEN="ice-token-2026"
LAVA_TOKEN="lava-token-2026"
AI_OTHER_TOKEN="ai-other-token-2026"

# Microsoft Teams bot webhook secret.
# REQUIRED to enable the Teams webhook: the /webhook endpoint fails closed
# (HTTP 503) while this is unset and rejects requests whose Bearer token does
# not match this value via constant-time comparison.
TEAMS_BOT_SECRET=

# Integration connectors (Microsoft / Atlassian OAuth)
# REQUIRED to enable the SharePoint/Teams (Microsoft) and Jira (Atlassian)
# connectors. While unset, clicking "Connect" in the UI fails with
# "<provider> OAuth not configured". Register the apps first, see:
#   docs/AZURE_APP_REGISTRATION.md  and  docs/ATLASSIAN_APP_REGISTRATION.md
# The OAuth callback is ${APP_URL}/api/admin/integrations/oauth/callback and
# must match the redirect URI registered in each provider exactly.
APP_URL="http://localhost:3000"

# Encrypts integration tokens at rest (AES-256-GCM; the value is SHA-256'd, so
# any string works). Generate once with:  openssl rand -hex 32
# Keep it STABLE: changing it makes every stored token undecryptable and forces
# all connectors to be re-authorized.
INTEGRATION_ENCRYPTION_KEY=

# Microsoft Entra ID (SharePoint, Teams), see docs/AZURE_APP_REGISTRATION.md
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=
MICROSOFT_REDIRECT_URI="http://localhost:3000/api/admin/integrations/oauth/callback"

# Atlassian (Jira), see docs/ATLASSIAN_APP_REGISTRATION.md
ATLASSIAN_CLIENT_ID=
ATLASSIAN_CLIENT_SECRET=
ATLASSIAN_REDIRECT_URI="http://localhost:3000/api/admin/integrations/oauth/callback"

# Server Configuration
PORT=3001
NODE_ENV=development
CLIENT_URL="http://localhost:4000"

# CORS Configuration
CORS_ORIGIN="http://localhost:4000"

# Rate Limiting
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX=5
REGISTER_RATE_LIMIT_WINDOW_MS=3600000
REGISTER_RATE_LIMIT_MAX=3

# Registration mode: open | invite | closed
# Unset defaults to `invite` for safe-by-default behaviour.
REGISTRATION_MODE=invite

# Security
BCRYPT_ROUNDS=12
SESSION_TIMEOUT_HUMAN=604800000
SESSION_TIMEOUT_AI=86400000

# File Upload
UPLOAD_MAX_SIZE=10485760
UPLOAD_DIR="./uploads"

# Logging
LOG_LEVEL="info"
LOG_FORMAT="json"