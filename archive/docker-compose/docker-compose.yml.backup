version: '3.8'

services:
  # PostgreSQL Database
  postgres:
    image: postgres:15-alpine
    container_name: triologue-postgres
    environment:
      POSTGRES_DB: triologue
      POSTGRES_USER: triologue_user
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD:-triologue_secure_password}
    volumes:
      - postgres_data:/var/lib/postgresql/data
      - ./database/init.sql:/docker-entrypoint-initdb.d/init.sql
    ports:
      - "5432:5432"
    networks:
      - triologue-network
    restart: unless-stopped
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U triologue_user -d triologue"]
      interval: 30s
      timeout: 10s
      retries: 3

  # Redis Cache
  redis:
    image: redis:7-alpine
    container_name: triologue-redis
    ports:
      - "6379:6379"
    volumes:
      - redis_data:/data
    networks:
      - triologue-network
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 30s
      timeout: 10s
      retries: 3

  # Backend API Server
  api:
    build:
      context: ./server
      dockerfile: Dockerfile
    container_name: triologue-api
    environment:
      NODE_ENV: production
      PORT: 3001
      DATABASE_URL: postgresql://triologue_user:${POSTGRES_PASSWORD:-triologue_secure_password}@postgres:5432/triologue
      REDIS_URL: redis://redis:6379
      JWT_SECRET: ${JWT_SECRET:-your-super-secret-jwt-key-change-in-production}
      CLIENT_URL: ${CLIENT_URL:-http://localhost:3000}
      CLAWDBOT_API_URL: ${CLAWDBOT_API_URL:-http://localhost:8080}
      ICE_WEBHOOK_URL: ${ICE_WEBHOOK_URL}
    ports:
      - "3001:3001"
    networks:
      - triologue-network
    depends_on:
      postgres:
        condition: service_healthy
      redis:
        condition: service_healthy
    restart: unless-stopped
    volumes:
      - ./server/uploads:/app/uploads
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:3001/api/health"]
      interval: 30s
      timeout: 10s
      retries: 3

  # Frontend React App
  frontend:
    build:
      context: ./client
      dockerfile: Dockerfile
      args:
        VITE_API_URL: ${VITE_API_URL:-http://localhost:3001}
        VITE_SOCKET_URL: ${VITE_SOCKET_URL:-http://localhost:3001}
    container_name: triologue-frontend
    ports:
      - "3000:80"
    networks:
      - triologue-network
    depends_on:
      - api
    restart: unless-stopped

  # Nginx Reverse Proxy (for production)
  nginx:
    image: nginx:alpine
    container_name: triologue-nginx
    ports:
      - "80:80"
      - "443:443"
    volumes:
      - ./nginx/nginx.conf:/etc/nginx/nginx.conf
      - ./nginx/ssl:/etc/nginx/ssl
    networks:
      - triologue-network
    depends_on:
      - frontend
      - api
    restart: unless-stopped
    profiles:
      - production

  # AI Bridge Service (for AI integrations)
  ai-bridge:
    build:
      context: ./ai-bridge
      dockerfile: Dockerfile
    container_name: triologue-ai-bridge
    environment:
      NODE_ENV: production
      API_URL: http://api:3001
      CLAWDBOT_SESSION_KEY: ${CLAWDBOT_SESSION_KEY}
      ICE_API_URL: ${ICE_API_URL}
      LAVA_CONSCIOUSNESS_API: ${LAVA_CONSCIOUSNESS_API}
    networks:
      - triologue-network
    depends_on:
      - api
    restart: unless-stopped
    profiles:
      - ai-integration

networks:
  triologue-network:
    driver: bridge

volumes:
  postgres_data:
    driver: local
  redis_data:
    driver: local